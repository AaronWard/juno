{
  "name": "juno-ace-proxy",
  "version": "1.0.0",
  "private": true,
  "description": "Juno local API/proxy: serves the built web UI and translates Juno API calls into ACE-Step API calls.",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
